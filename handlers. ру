@router.message(Command("admin"))
async def cmd_admin(message: Message):
    if message.from_user.id not in ADMIN_IDS:
        await message.answer("Доступ запрещён")
        return
    from database import supabase
    users = len(supabase.table("users").select("*").execute().data)
    cases = len(supabase.table("cases").select("*").execute().data)
    active = len([c for c in supabase.table("cases").select("*").execute().data if c["status"] == "draft"])
    await message.answer(
        f"👑 Админ-панель\n\n"
        f"👥 Пользователей: {users}\n"
        f"📋 Кейсов: {cases}\n"
        f"⏳ Активных (draft): {active}"
    )
