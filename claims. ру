def generate_claim(case: dict) -> str:
    type_map = {
        "return": "возврат товара",
        "substitution": "подмену товара",
        "defect": "брак",
        "non_buyout": "невыкуп",
        "loss": "потерю",
        "damage": "повреждение",
        "dispute": "спор с покупателем"
    }
    problem = type_map.get(case.get("type"), "проблему")
    return f"""Официальная претензия

Кому: Маркетплейс (Ozon/Wildberries)
От: Селлер, заказ №{case.get('order_number', 'не указан')}

Уважаемые коллеги!

Я, селлер, обращаюсь с претензией по заказу №{case.get('order_number', 'не указан')} в связи с {problem}.

Описание ситуации:
{case.get('description', 'не указано')}

Прилагаю доказательства: фото и скриншоты.

На основании правил маркетплейса прошу пересмотреть решение по данному спору.

Срок ответа — 7 рабочих дней.

С уважением,
Селлер"""

def get_checklist() -> list[str]:
    return [
        "Собрать все доказательства (фото, скриншоты).",
        "Составить письменное обращение.",
        "Отправить претензию через поддержку маркетплейса.",
        "Отслеживать статус обращения.",
        "При отсутствии ответа — подготовить повторное обращение."
    ]
